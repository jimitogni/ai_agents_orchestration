API_HOST_PORT=8010
CHROMA_HOST_PORT=8011
OLLAMA_HOST_PORT=11434

# Required when using a Traefik overlay.
RAG_AGENT_HOST=rag.example.com
TRAEFIK_NETWORK=traefik_proxy

# Required only when using docker-compose.traefik.http.yml.
TRAEFIK_HTTP_ENTRYPOINT=web

# Required only when using docker-compose.traefik.yml for HTTPS.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
# Required only when using docker-compose.traefik.basicauth.yml.
# Generate with:
# htpasswd -nbB admin 'change-me' | sed -e 's/\\$/\\$\\$/g'
TRAEFIK_BASIC_AUTH_USERS=admin:CHANGE_ME

LOG_LEVEL=INFO
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120

CHROMA_COLLECTION_NAME=internal_docs
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=4
CHUNK_SIZE=900
CHUNK_OVERLAP=120
